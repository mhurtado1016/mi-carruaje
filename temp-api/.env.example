DB_HOST=localhost
DB_PORT=3306
DB_NAME=routetrack
DB_USER=root
DB_PASS=

# Clave que los clientes deben enviar como: Authorization: Bearer <API_KEY>
API_KEY=change_this_in_production

# IPs autorizadas para consumir el API (separadas por coma).
# Dejar vacío para desactivar la restricción.
# Ejemplo: ALLOWED_IPS=203.0.113.42,203.0.113.43
ALLOWED_IPS=

# Activar solo si el servidor está detrás de un proxy o load balancer (ej: Nginx, Cloudflare).
# Permite leer la IP real del cliente desde el header X-Forwarded-For.
TRUST_PROXY=false
